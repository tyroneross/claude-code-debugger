{
  "PreToolUse": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "npx @tyroneross/claude-code-debugger check-file \"$TOOL_INPUT_FILE_PATH\" 2>/dev/null || true",
          "timeout": 5000
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "npx @tyroneross/claude-code-debugger capture-error 2>/dev/null || true",
          "timeout": 5000
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "npx @tyroneross/claude-code-debugger mine --days 1 --store 2>/dev/null || true",
          "timeout": 30000
        }
      ]
    }
  ]
}
